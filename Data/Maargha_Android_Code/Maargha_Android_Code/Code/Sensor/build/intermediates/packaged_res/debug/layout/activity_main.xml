<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Thumbnail View for Camera Pipeline -->
    <ImageView
        android:id="@+id/imageView1"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_launcher" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MAARGHA"
        android:textColor="#38BDF8"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GNSS Telemetry Engine"
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:layout_marginBottom="32dp" />

    <!-- Control Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E293B"
        android:padding="24dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SESSION LOG NAME"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/editText1"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#38BDF8"
            android:textColor="#FFFFFF"
            android:hint="Enter Alias (Optional)"
            android:textColorHint="#475569"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/button1"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="#10B981"
            android:text="START LOGGING"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:onClick="Start"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/button3"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#334155"
            android:text="View Saved Data"
            android:textColor="#F8FAFC"
            android:textSize="14sp"
            android:onClick="ViewData"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/button2"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="#334155"
            android:text="Hardware Settings"
            android:textColor="#F8FAFC"
            android:textSize="14sp"
            android:onClick="Settings" />

    </LinearLayout>

    <!-- Invisible Mandatory Camera FrameBuffer for Legacy Support -->
    <FrameLayout
        android:id="@+id/preview" 
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="invisible">
    </FrameLayout>

    <TextView
        android:id="@+id/textView1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="System Ready"
        android:textColor="#64748B"
        android:textSize="14sp" />

</LinearLayout>